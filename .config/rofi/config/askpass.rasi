@import "colors.rasi"
@import "font.rasi"

* {
    background-color:	@active-background;
    text-color:         @urgent-foreground;
}

window {
    width:        	350px;
    padding:    	20px;
    border:		2px 2px 2px 2px;
    border-radius:      10px;
    border-color:       @bordercolor;
    location:           0;
    x-offset:           0;
    y-offset:           -4%;
}

entry {
    expand: 		true;
    width: 		300px;
    text-color:		@foreground;
}
