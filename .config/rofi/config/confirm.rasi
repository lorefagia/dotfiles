@import "colors.rasi"
@import "font.rasi"

* {
    background-color:	@background-color;
    text-color:         @foreground;
}

window {
    width:      	300px;
    padding:            20px;
    border:		2px 2px 2px 2px;
    border-radius:      8px;
    border-color:       @bordercolor;
    location:           0;
    x-offset:           0;
    y-offset:           -4%;
}

entry {
    expand: 		true;
    width: 		150px;
    text-color:		@bordercolor;
}
